# Skopiuj jako .env (lub uzupełnij istniejący .env) przed: docker compose up -d
DIRECTUS_PORT=5056
PUBLIC_URL=http://localhost:5056
DIRECTUS_URL = http://localhost:5056
DIRECTUS_TOKEN=twoj-directus-token

# Wymagane – wygeneruj: openssl rand -hex 32
KEY=twoj-losowy-klucz-32-znaki-hex
SECRET=twoj-losowy-sekret-32-znaki-hex

# Baza PostgreSQL (w Dockerze)
POSTGRES_USER=directus
POSTGRES_PASSWORD=directus
POSTGRES_DB=directus

# Admin Directus (do pierwszego logowania)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
